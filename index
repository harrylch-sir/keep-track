    <!-- 🔥 導入 Firebase (專案核心即時雲端雙向同步) 🔥 -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // === 系統全域變數 ===
        const apiKey = ""; 
        window.leafletMap = null;
        window.currentRole = 'senior';
        
        const DEFAULT_COORDS = [22.4251, 114.2326]; 
        window.currentCoords = [...DEFAULT_COORDS];
        window.currentAddress = "等待獲取真實地址..."; 
        window.mapMarker = null;
        window.gpsWatchId = null;

        window.homeCoords = [22.4260, 114.2310]; 
        window.homeSettingMap = null;
        window.homeSettingMarker = null;

        window.stepCount = 0;
        window.isPedometerActive = false;
        window.lastMotionPeakTime = 0;
        window.currentHeartRate = "--";
        window.heartRateInterval = null;
        
        window.safeZoneRadius = 500;
        window.isSafeZoneActive = false;
        window.safeZoneMap = null;
        window.safeZoneMarker = null;
        window.safeZoneCircleMap = null;
        window.safeZoneCenterCoords = [...DEFAULT_COORDS]; 

        window.hrBleDevice = null;
        window.isRealHeartRateActive = false;
        window.isSOSActive = false;
        window.familySosTriggered = false;
        window.lastCommandTimestamp = 0; // 用於辨識家人指令

        // Firebase 初始化變數
        let app, auth, db, appId, cloudUser;
        const DEMO_ROOM_ID = "shared_room"; // 兩部手機共用的虛擬房間

        try {
            const firebaseConfig = JSON.parse(typeof __firebase_config !== 'undefined' ? __firebase_config : '{}');
            app = initializeApp(firebaseConfig);
            auth = getAuth(app);
            db = getFirestore(app);
            appId = typeof __app_id !== 'undefined' ? __app_id : 'demo-app-id';
            
            async function initAuth() {
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await signInAnonymously(auth);
                }
            }
            initAuth();

            onAuthStateChanged(auth, (user) => {
                cloudUser = user;
                if (user) {
                    document.getElementById('cloud-sync-indicator').classList.remove('hidden');
                    startListeningToCloud(); // 不論長者或家人，都啟動雙向監聽
                    if (window.currentRole === 'senior' || window.currentRole === 'split') window.pushDataToCloud();
                }
            });
        } catch(e) {
            console.warn("未能載入雲端資料庫，將改為本機單機展示模式。");
        }

        // ==========================================
        //  🌟 雲端即時雙向同步核心邏輯 🌟
        // ==========================================
        
        // 【上行】長者端：將日常數據推播到雲端 (綁定至 window 以便全域呼叫)
        window.pushDataToCloud = function() {
            // 修正：允許 'senior' 與 'split' 模式進行上傳
            if (!cloudUser || !db || (window.currentRole !== 'senior' && window.currentRole !== 'split')) return;
            const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'sessions', DEMO_ROOM_ID);
            setDoc(docRef, {
                heartRate: window.currentHeartRate,
                stepCount: window.stepCount,
                coords: window.currentCoords,
                address: window.currentAddress,
                sos: window.isSOSActive,
                timestamp: Date.now()
            }, { merge: true }).catch(e => console.error("雲端同步失敗", e));
        }

        // 長者端定時更新
        setInterval(() => {
            if (window.currentRole === 'senior' || window.currentRole === 'split') window.pushDataToCloud();
        }, 2000);

        // 【下行】家人端：發送遠端指令給長者
        window.sendWrongWayCommand = function() {
            if (!cloudUser || !db) return window.showCustomAlert("未連線", "目前處於單機模式，無法發送雲端指令。", "wifi-off", "red");
            const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'sessions', DEMO_ROOM_ID);
            setDoc(docRef, {
                familyCommand: 'wrong_way',
                commandTimestamp: Date.now()
            }, { merge: true });
            window.showCustomAlert("指令已發送", "「偏離路線」警報已成功發送至長者手機！", "check-circle", "green");
        };

        // 【雙向監聽】家人與長者共同的雲端雷達
        let unsubCloud = null;
        function startListeningToCloud() {
            if (!cloudUser || !db) return;
            const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'sessions', DEMO_ROOM_ID);
            
            if (unsubCloud) unsubCloud();
            
            unsubCloud = onSnapshot(docRef, (docSnap) => {
                if (docSnap.exists()) {
                    const data = docSnap.data();
                    
                    // === 家人端：接收長者的數據與求救 ===
                    if (window.currentRole === 'family' || window.currentRole === 'split') {
                        if (data.stepCount !== undefined && data.stepCount !== window.stepCount) {
                            window.stepCount = data.stepCount;
                            const el = document.getElementById('family-step-count');
                            if(el) {
                                el.innerText = window.stepCount;
                                el.classList.add('text-green-500', 'scale-125');
                                setTimeout(() => el.classList.remove('text-green-500', 'scale-125'), 300);
                            }
                        }
                        
                        if (data.heartRate !== undefined && data.heartRate !== window.currentHeartRate) {
                            window.currentHeartRate = data.heartRate;
                            const hrEl = document.getElementById('family-heart-rate');
                            if(hrEl) {
                                hrEl.innerText = window.currentHeartRate;
                                hrEl.classList.add('scale-125');
                                setTimeout(() => hrEl.classList.remove('scale-125'), 150);
                            }
                        }
                        
                        if (data.coords && (data.coords[0] !== window.currentCoords[0] || data.coords[1] !== window.currentCoords[1])) {
                            window.currentCoords = data.coords;
                            window.initOrUpdateMap(window.currentCoords, "長者即時位置 (雲端)");
                            document.getElementById('family-gps-dot').classList.replace('bg-gray-400', 'bg-green-500');
                            document.getElementById('family-gps-dot').classList.add('animate-pulse');
                            document.getElementById('family-gps-status').innerText = "即時同步中";
                            
                            if (window.isSafeZoneActive) {
                                const distToCenter = calculateDistance(data.coords[0], data.coords[1], window.safeZoneCenterCoords[0], window.safeZoneCenterCoords[1]);
                                if (distToCenter > window.safeZoneRadius) window.triggerSafeZoneAlert();
                            }
                        }
                        
                        if (data.address && data.address !== window.currentAddress) {
                            window.currentAddress = data.address;
                            const addrEl = document.getElementById('family-address-text');
                            if(addrEl) addrEl.innerText = window.currentAddress;
                        }
                        
                        if (data.sos && !window.familySosTriggered) {
                            window.familySosTriggered = true;
                            document.getElementById('sos-alert').classList.remove('hidden');
                            if (window.currentRole === 'split') document.getElementById('sos-alert').scrollIntoView({ behavior: 'smooth', block: 'center' });
                            try { let u = new SpeechSynthesisUtterance("緊急求助！長者已觸發救援按鈕！"); u.lang='zh-HK'; window.speechSynthesis.speak(u); } catch(e){}
                        } else if (!data.sos && window.familySosTriggered) {
                            window.familySosTriggered = false;
                            document.getElementById('sos-alert').classList.add('hidden');
                        }
                    }

                    // === 長者端：接收家人傳來的遠端指令 ===
                    if (window.currentRole === 'senior' || window.currentRole === 'split') {
                        if (data.familyCommand && data.commandTimestamp > window.lastCommandTimestamp) {
                            if (window.lastCommandTimestamp === 0) {
                                window.lastCommandTimestamp = data.commandTimestamp; // 第一次載入時忽略舊指令
                            } else {
                                window.lastCommandTimestamp = data.commandTimestamp;
                                if (data.familyCommand === 'wrong_way') {
                                    window.triggerWrongWayAlertLocal(); // 觸發長者畫面的專屬警告
                                }
                            }
                        }
                    }
                }
            });
        }


        // ==========================================
        //  一般應用程式邏輯 (綁定至 window 以供 HTML 呼叫)
        // ==========================================
        document.addEventListener('DOMContentLoaded', () => {
            if (typeof lucide !== 'undefined') lucide.createIcons();
            if ("geolocation" in navigator) {
                navigator.geolocation.getCurrentPosition(
                    (pos) => { 
                        window.currentCoords = [pos.coords.latitude, pos.coords.longitude]; 
                        window.updateAddressFromCoords(window.currentCoords[0], window.currentCoords[1]);
                    },
                    (err) => {}, { enableHighAccuracy: true, timeout: 5000 }
                );
            }
        });

        window.updateAddressFromCoords = async function(lat, lng) {
            try {
                const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18&addressdetails=1`);
                const data = await response.json();
                if (data && data.display_name) {
                    let shortAddress = data.address.amenity || data.address.building || data.address.road || data.address.suburb || data.display_name.split(',')[0];
                    window.currentAddress = shortAddress + " 附近";
                    
                    if(window.currentRole === 'senior' || window.currentRole === 'split') {
                        document.getElementById('current-location-text').innerText = window.currentAddress;
                        if(window.pushDataToCloud) window.pushDataToCloud(); 
                    }
                }
            } catch (e) {}
        }

        window.launchApp = function(mode) {
            document.getElementById('launch-screen').classList.add('opacity-0', 'pointer-events-none');
            setTimeout(() => {
                document.getElementById('launch-screen').classList.add('hidden');
                document.getElementById('main-app').classList.remove('hidden');
                setTimeout(() => document.getElementById('main-app').classList.remove('opacity-0'), 50);
                document.getElementById('role-selector').value = mode;
                window.switchRole(mode);
            }, 500);
        }

        window.switchRole = function(role) {
            window.currentRole = role;
            const seniorPage = document.getElementById('page-senior');
            const familyPage = document.getElementById('page-family');
            const splitWrapper = document.getElementById('split-wrapper');
            const body = document.getElementById('main-body');
            const appContainer = document.getElementById('app-container');

            seniorPage.classList.add('hidden');
            familyPage.classList.add('hidden');
            splitWrapper.classList.remove('split-view');
            appContainer.classList.add('max-w-md');
            appContainer.classList.remove('max-w-5xl');

            if (role === 'senior') {
                seniorPage.classList.remove('hidden');
                body.className = 'min-h-screen gradient-bg-senior transition-colors duration-700';
                window.startGPSBackgroundWatch(); 
                if (cloudUser) startListeningToCloud(); // 長者也要監聽
            } else if (role === 'family') {
                familyPage.classList.remove('hidden');
                body.className = 'min-h-screen gradient-bg-family transition-colors duration-700';
                window.generateFamilyAISummary();
                if (cloudUser) startListeningToCloud(); 
            } else if (role === 'split') {
                seniorPage.classList.remove('hidden');
                familyPage.classList.remove('hidden');
                splitWrapper.classList.add('split-view');
                appContainer.classList.remove('max-w-md');
                appContainer.classList.add('max-w-5xl');
                body.className = 'min-h-screen bg-gray-100 transition-colors duration-700 p-8';
                window.startGPSBackgroundWatch();
                window.generateFamilyAISummary();
                if (cloudUser) startListeningToCloud();
            }
            if(window.leafletMap) setTimeout(() => window.leafletMap.invalidateSize(), 300);
        }

        window.showCustomAlert = function(title, message, iconName = 'info', colorTheme = 'blue') {
            const modal = document.getElementById('custom-alert-modal');
            document.getElementById('custom-alert-title').innerText = title;
            document.getElementById('custom-alert-message').innerHTML = message.replace(/\n/g, '<br>');
            
            const iconContainer = document.getElementById('custom-alert-icon-container');
            const themeMap = { 'blue': { bg: 'bg-blue-100', text: 'text-blue-600' }, 'red': { bg: 'bg-red-100', text: 'text-red-600' }, 'green': { bg: 'bg-green-100', text: 'text-green-600' } };
            const theme = themeMap[colorTheme] || themeMap['blue'];
            iconContainer.className = `mx-auto p-4 rounded-full w-16 h-16 flex items-center justify-center mb-4 ${theme.bg}`;
            iconContainer.innerHTML = `<i id="custom-alert-icon" data-lucide="${iconName}" class="${theme.text}" size="32"></i>`;
            if (typeof lucide !== 'undefined') lucide.createIcons();

            modal.classList.remove('hidden');
            setTimeout(() => { document.getElementById('custom-alert-content').classList.replace('scale-95', 'scale-100'); }, 10);
        }

        window.closeCustomAlert = function() {
            document.getElementById('custom-alert-content').classList.replace('scale-100', 'scale-95');
            setTimeout(() => document.getElementById('custom-alert-modal').classList.add('hidden'), 300);
        }

        window.openGoogleMapsNavigation = function() {
            const googleMapsUrl = `https://www.google.com/maps/dir/?api=1&destination=${window.homeCoords[0]},${window.homeCoords[1]}&travelmode=walking`;
            try { let u = new SpeechSynthesisUtterance("正在為您開啟 Google Maps 導航，帶您平安回家！"); u.lang='zh-HK'; window.speechSynthesis.speak(u); } catch(e){}
            window.showCustomAlert("啟動實時導航", "正在為您開啟 Google Maps 進行即時語音步行導航，帶您平安回家！", "map-pin", "green");
            setTimeout(() => { window.open(googleMapsUrl, '_blank'); }, 1500);
        }

        window.initHTML5Sensors = async function() {
            if(window.isPedometerActive) return;
            if (typeof DeviceMotionEvent !== 'undefined' && typeof DeviceMotionEvent.requestPermission === 'function') {
                try {
                    const permissionState = await DeviceMotionEvent.requestPermission();
                    if (permissionState !== 'granted') return window.showCustomAlert("權限遭拒", "必須允許動作感測器權限！", "shield-alert", "red");
                } catch (error) { return; }
            }
            window.isPedometerActive = true;
            document.getElementById('sensor-start-btn').style.display = 'none';
            document.getElementById('ble-connect-btn').style.display = 'none'; 
            document.getElementById('pedometer-status').classList.replace('bg-gray-300', 'bg-green-500');
            document.getElementById('pedometer-status').classList.add('animate-pulse');
            
            window.addEventListener('devicemotion', (e) => {
                const acc = e.accelerationIncludingGravity;
                if (!acc || acc.x === null) return;
                const mag = Math.sqrt(acc.x*acc.x + acc.y*acc.y + acc.z*acc.z);
                if (mag > 11.5 && (Date.now() - window.lastMotionPeakTime) > 350) {
                    window.stepCount++;
                    window.lastMotionPeakTime = Date.now();
                    window.updateStepUI(window.stepCount); // 觸發即時推播
                }
            });
            window.showCustomAlert("計步已啟動", "✅ 真實手機計步已啟動！", "footprints", "green");
            if (!window.isRealHeartRateActive && !window.heartRateInterval) {
                window.heartRateInterval = setInterval(() => {
                    window.currentHeartRate = 70 + Math.floor(Math.random() * 15);
                    document.getElementById('heart-rate').innerText = window.currentHeartRate;
                    if(window.pushDataToCloud) window.pushDataToCloud();
                }, 3000);
            }
        }

        window.connectMicroBit = async function() {
            const btn = document.getElementById('ble-connect-btn');
            if (!navigator.bluetooth) return window.showCustomAlert("不支援藍牙", "瀏覽器不支援網頁藍牙。", "bluetooth-off", "red");
            btn.innerHTML = `<i data-lucide="loader" size="12" class="animate-spin"></i> 連線中...`;
            if (typeof lucide !== 'undefined') lucide.createIcons();
            try {
                const device = await navigator.bluetooth.requestDevice({ filters: [{ namePrefix: 'BBC micro:bit' }], optionalServices: ['6e400001-b5a3-f393-e0a9-e50e24dcca9e'] });
                const server = await device.gatt.connect();
                const characteristic = await (await server.getPrimaryService('6e400001-b5a3-f393-e0a9-e50e24dcca9e')).getCharacteristic('6e400002-b5a3-f393-e0a9-e50e24dcca9e');
                await characteristic.startNotifications();
                
                characteristic.addEventListener('characteristicvaluechanged', (e) => {
                    let str = new TextDecoder().decode(e.target.value).trim();
                    if (str.includes("SOS")) {
                        window.triggerSOS();
                    } else if (str.includes("STEP:")) { 
                        window.stepCount = parseInt(str.split("STEP:")[1]); 
                        window.updateStepUI(window.stepCount); 
                    } else if (!isNaN(parseInt(str))) {
                        // 修復：支援 micro:bit 發送純數字
                        window.stepCount = parseInt(str);
                        window.updateStepUI(window.stepCount);
                    }
                });
                
                btn.innerHTML = `<i data-lucide="bluetooth-connected" size="12"></i> 手環已連接`;
                btn.classList.replace('bg-indigo-100', 'bg-green-100'); btn.classList.replace('text-indigo-700', 'text-green-700');
                document.getElementById('pedometer-status').classList.replace('bg-gray-300', 'bg-blue-500');
                document.getElementById('sensor-start-btn').style.display = 'none'; 
                window.showCustomAlert("連線成功", "已連接 micro:bit！", "bluetooth-connected", "green");
            } catch (error) { btn.innerHTML = `連線失敗重試`; }
        }

        window.connectHeartRateMonitor = async function() {
            const btn = document.getElementById('hr-ble-connect-btn');
            if (!navigator.bluetooth) return;
            btn.innerHTML = `<i data-lucide="loader" size="12" class="animate-spin"></i> 連線中...`;
            try {
                const device = await navigator.bluetooth.requestDevice({ filters: [{ services: ['heart_rate'] }] });
                const characteristic = await (await (await device.gatt.connect()).getPrimaryService('heart_rate')).getCharacteristic('heart_rate_measurement');
                await characteristic.startNotifications();
                characteristic.addEventListener('characteristicvaluechanged', (e) => {
                    const value = e.target.value;
                    window.currentHeartRate = (value.getUint8(0) & 0x1) ? value.getUint16(1, true) : value.getUint8(1);
                    document.getElementById('heart-rate').innerText = window.currentHeartRate;
                    if(window.pushDataToCloud) window.pushDataToCloud(); // 即時推播心率
                });
                window.isRealHeartRateActive = true;
                if (window.heartRateInterval) clearInterval(window.heartRateInterval);
                btn.innerHTML = `<i data-lucide="bluetooth-connected" size="12"></i> 已連接心跳帶`;
                btn.classList.replace('bg-rose-100', 'bg-green-100'); btn.classList.replace('text-rose-700', 'text-green-700');
                document.getElementById('hr-ble-status').classList.replace('bg-gray-300', 'bg-rose-500');
                window.showCustomAlert("連線成功", `已連接心跳設備！`, "heart-pulse", "green");
            } catch (error) { btn.innerHTML = `連線失敗重試`; }
        }

        window.updateStepUI = function(steps) {
            document.getElementById('step-count').innerText = steps;
            if(document.getElementById('family-step-count')) document.getElementById('family-step-count').innerText = steps;
            // 觸發即時推播！
            if(window.pushDataToCloud) window.pushDataToCloud(); 
        }

        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371e3, p1 = lat1 * Math.PI/180, p2 = lat2 * Math.PI/180;
            const a = Math.sin((lat2-lat1)*Math.PI/360)**2 + Math.cos(p1)*Math.cos(p2)*Math.sin((lon2-lon1)*Math.PI/360)**2;
            return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        }

        window.startGPSBackgroundWatch = function() {
            if ("geolocation" in navigator && window.currentRole !== 'family') {
                window.gpsWatchId = navigator.geolocation.watchPosition(
                    (position) => {
                        window.currentCoords = [position.coords.latitude, position.coords.longitude];
                        window.updateAddressFromCoords(window.currentCoords[0], window.currentCoords[1]);
                    }, (err) => {}, { enableHighAccuracy: true, maximumAge: 10000 }
                );
            }
        }

        window.initOrUpdateMap = function(coords, popupText) {
            if (!window.leafletMap) {
                window.leafletMap = L.map('map-container').setView(coords, 17);
                L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(window.leafletMap);
                const customIcon = L.divIcon({ className: 'custom-div-icon', html: `<div style="background-color:#ef4444; width:20px; height:20px; border-radius:50%; border:3px solid white; box-shadow:0 0 10px rgba(0,0,0,0.5); animation: pulse 2s infinite;"></div>`, iconSize: [20, 20], iconAnchor: [10, 10] });
                window.mapMarker = L.marker(coords, {icon: customIcon}).addTo(window.leafletMap).bindPopup(`<b>📍 ${popupText}</b>`).openPopup();
            } else {
                window.leafletMap.setView(coords, 17);
                if(window.mapMarker) window.mapMarker.setLatLng(coords).setPopupContent(`<b>📍 ${popupText}</b>`).openPopup();
                window.leafletMap.invalidateSize();
            }
        }

