        // --- Gemini AI ---
        window.callGoogleMapGeminiFunction = async function() {
            const envText = document.getElementById('report-env');
            envText.innerHTML = `<span class="animate-pulse text-indigo-500">🗺️ Gemini 正在分析周邊路況...</span>`;
            const prompt = `你是一個無障礙導航助理。長者目前位於「${window.currentAddress}」。請用廣東話口語，三句話內告訴長者這區有什麼環境特徵，及提醒步行安全。`;
            const textResponse = await window.callGeminiText(prompt);
            envText.innerHTML = `<span class="text-indigo-700 font-bold">🗺️ 智能路況分析：</span><br>${textResponse}`;
            window.callGeminiTTS(textResponse);
        }

        window.readLocationReport = async function() {
            const envText = document.getElementById('report-env');
            envText.innerText = "Gemini 正在生成語音...";
            const textResponse = await window.callGeminiText(`長者目前位於「${window.currentAddress}」。請用大約兩句話，以廣東話口吻溫柔地告訴他現在的位置。`);
            envText.innerText = textResponse;
