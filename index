        }

        window.closeMap = function() {
            document.getElementById('map-modal-content').classList.replace('scale-100', 'scale-95');
            setTimeout(() => document.getElementById('map-modal').classList.add('hidden'), 300);
        }

        window.openSafeZoneModal = function() {
            document.getElementById('safe-zone-modal').classList.remove('hidden');
            setTimeout(() => { 
                document.getElementById('safe-zone-modal-content').classList.replace('scale-95', 'scale-100');
                if (!window.isSafeZoneActive) window.safeZoneCenterCoords = [...window.homeCoords];
                if (!window.safeZoneMap) {
                    window.safeZoneMap = L.map('safe-zone-map-container').setView(window.safeZoneCenterCoords, 15);
                    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(window.safeZoneMap);
                    window.safeZoneMarker = L.marker(window.safeZoneCenterCoords, {icon: L.divIcon({ html: `<div style="background-color:#2563eb; width:16px; height:16px; border-radius:50%; border:3px solid white;"></div>`, iconSize:[16,16]}), draggable: true}).addTo(window.safeZoneMap);
                    window.safeZoneCircleMap = L.circle(window.safeZoneCenterCoords, { color: '#3b82f6', fillOpacity: 0.2, radius: window.safeZoneRadius }).addTo(window.safeZoneMap);
                    window.safeZoneMarker.on('drag', e => window.safeZoneCircleMap.setLatLng(e.latlng));
                    window.safeZoneMarker.on('dragend', e => window.safeZoneCenterCoords = [e.target.getLatLng().lat, e.target.getLatLng().lng]);
                } else {
                    window.safeZoneMap.invalidateSize(); window.safeZoneMap.setView(window.safeZoneCenterCoords, 15);
                }
