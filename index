<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>憶路守護 - 智慧照護系統</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- 引入 Leaflet 地圖套件 -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700;900&display=swap');
        body { font-family: 'Noto Sans TC', sans-serif; touch-action: manipulation; overflow-x: hidden; }
        
        .gradient-bg-senior { background: linear-gradient(180deg, #f0f9ff 0%, #e0f2fe 100%); }
        .gradient-bg-family { background: linear-gradient(180deg, #fdf2f8 0%, #fce7f3 100%); }
        .bg-launch { background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); }

        .fade-in { animation: fadeIn 0.5s ease-out forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .pulse-slow { animation: pulse 3s infinite; }
        @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }

        ::-webkit-scrollbar { display: none; }
        .leaflet-container { z-index: 10 !important; font-family: 'Noto Sans TC', sans-serif; }
        .leaflet-div-icon { background: transparent; border: none; }
        
        .split-view { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 24px; 
            min-width: 750px;
            align-items: stretch;
        }
        .step-update { transition: all 0.3s ease; }
    </style>
</head>
<body id="main-body" class="min-h-screen bg-launch transition-colors duration-700">

    <!-- ================= 啟動主畫面 ================= -->
    <div id="launch-screen" class="fixed inset-0 z-[1000] flex flex-col items-center justify-center p-6 text-white text-center transition-opacity duration-500">
        <div class="mb-12 fade-in">
            <div class="bg-white/20 p-6 rounded-full inline-block mb-4 backdrop-blur-md pulse-slow">
                <i data-lucide="shield-check" size="64" class="text-white"></i>
            </div>
            <h1 class="text-5xl font-black tracking-tight mb-2">憶路守護</h1>
            <p class="text-indigo-100 font-bold tracking-wide">長者防走失智慧照護系統</p>
        </div>

        <div class="w-full max-w-sm space-y-4 fade-in" style="animation-delay: 0.2s">
            <button onclick="launchApp('senior')" class="group w-full bg-white text-indigo-600 p-6 rounded-3xl shadow-2xl flex items-center justify-between hover:scale-[1.02] active:scale-95 transition-all">
                <div class="flex items-center gap-4">
                    <div class="bg-blue-100 p-3 rounded-2xl group-hover:bg-blue-200 transition-colors">
                        <i data-lucide="user" size="32"></i>
                    </div>
                    <div class="text-left">
                        <span class="block text-xl font-black">長者模式</span>
                        <span class="block text-xs text-gray-500">連結硬體、發送即時同步數據</span>
                    </div>
                </div>
                <i data-lucide="chevron-right"></i>
            </button>

            <button onclick="launchApp('family')" class="group w-full bg-white/10 border-2 border-white/20 text-white p-6 rounded-3xl backdrop-blur-md flex items-center justify-between hover:bg-white/20 active:scale-95 transition-all">
                <div class="flex items-center gap-4">
                    <div class="bg-white/20 p-3 rounded-2xl">
                        <i data-lucide="heart" size="32"></i>
                    </div>
                    <div class="text-left">
                        <span class="block text-xl font-black">家人模式</span>
                        <span class="block text-xs text-white/60">接收雲端數據、實時遠端追蹤</span>
                    </div>
                </div>
                <i data-lucide="chevron-right"></i>
            </button>

            <button onclick="launchApp('split')" class="w-full bg-amber-500 text-white p-4 rounded-2xl shadow-lg flex items-center justify-center gap-2 font-bold mt-4 hover:bg-amber-600 transition-colors">
                <i data-lucide="columns"></i> 開啟雙屏演示 (單機展示用)
            </button>
        </div>
    </div>

    <!-- ================= 應用程式主內容 ================= -->
    <div id="main-app" class="hidden opacity-0 transition-opacity duration-700">
        <nav class="bg-white shadow-md p-4 sticky top-0 z-50">
            <div class="flex justify-between items-center max-w-6xl mx-auto">
                <h1 class="text-xl font-bold text-blue-600 flex items-center gap-2" onclick="location.reload()" style="cursor: pointer">
                    <i data-lucide="shield-check"></i> <span class="hidden sm:inline">憶路守護</span>
                </h1>
                
                <div class="flex items-center gap-2">
                    <span id="cloud-sync-indicator" class="hidden text-xs font-bold text-green-600 bg-green-50 px-2 py-1 rounded-md border border-green-200 animate-pulse"><i data-lucide="cloud-lightning" size="14" class="inline"></i> 雙向同步中</span>
                    <select id="role-selector" onchange="switchRole(this.value)" class="text-sm border rounded-lg px-2 py-1 bg-gray-50 outline-none font-bold text-gray-700 shadow-sm cursor-pointer">
                        <option value="senior">👴 長者模式</option>
                        <option value="family">❤️ 家人模式</option>
                        <option value="split">📱 雙屏演示</option>
                    </select>
                </div>
            </div>
        </nav>

        <div id="app-container" class="w-full max-w-md mx-auto p-4 transition-all duration-500">
            <div id="split-wrapper" class="w-full transition-all duration-500">
                
                <!-- ================= 長者端介面 ================= -->
                <main id="page-senior" class="space-y-4 relative h-full">
                    <div class="bg-white p-4 rounded-3xl shadow-sm border-2 border-blue-100 relative h-full flex flex-col overflow-hidden">
                        <h3 class="text-blue-600 font-black mb-3 text-center tracking-widest text-sm bg-blue-50 py-1 rounded-full w-1/2 mx-auto">👴 長者端手機</h3>
                        
                        <div class="grid grid-cols-2 gap-3 mb-4">
                            <div class="flex flex-col gap-3 h-48">
                                <section class="bg-slate-50 rounded-2xl p-3 shadow-inner border border-slate-200 flex-1 flex flex-col justify-center relative overflow-hidden">
                                    <div class="flex justify-between items-center relative z-10 mb-1">
                                        <h3 class="text-xs font-bold text-gray-700">今日步數</h3>
                                        <span id="pedometer-status" class="w-2 h-2 rounded-full bg-gray-300 transition-colors"></span>
                                    </div>
                                    <div class="text-left relative z-10 flex items-baseline gap-1">
                                        <span id="step-count" class="text-3xl font-black text-blue-600 step-update inline-block">0</span>
                                        <span class="text-[10px] text-blue-400 font-bold">步</span>
                                    </div>
                                    <div class="flex flex-col gap-1 mt-1 z-10 relative">
                                        <button id="sensor-start-btn" onclick="initHTML5Sensors()" class="bg-blue-100 text-blue-700 py-1 rounded-lg font-bold text-[10px] flex items-center justify-center gap-1 hover:bg-blue-200 transition-colors">
                                            <i data-lucide="smartphone" size="12"></i> 手機計步
                                        </button>
                                        <button id="ble-connect-btn" onclick="connectMicroBit()" class="bg-indigo-100 text-indigo-700 py-1 rounded-lg font-bold text-[10px] flex items-center justify-center gap-1 hover:bg-indigo-200 transition-colors">
                                            <i data-lucide="bluetooth" size="12"></i> 藍牙連接手環
                                        </button>
                                    </div>
                                    <i data-lucide="footprints" class="absolute -right-2 -bottom-2 text-slate-200 w-16 h-16 z-0 opacity-50 transform -rotate-12"></i>
                                </section>

                                <section class="bg-rose-50 rounded-2xl p-3 shadow-inner border border-rose-100 flex-1 flex flex-col justify-center relative overflow-hidden">
                                    <div class="flex justify-between items-center relative z-10 mb-1">
                                        <h3 class="text-xs font-bold text-rose-800">即時心率</h3>
                                        <span id="hr-ble-status" class="w-2 h-2 rounded-full bg-gray-300 transition-colors"></span>
                                    </div>
                                    <div class="text-left relative z-10 flex items-baseline gap-1">
                                        <span id="heart-rate" class="text-3xl font-black text-rose-600 transition-transform duration-150 inline-block">--</span>
                                        <span class="text-[10px] text-rose-400 font-bold">bpm</span>
                                    </div>
                                    <div class="flex flex-col gap-1 mt-1 z-10 relative">
                                        <button id="hr-ble-connect-btn" onclick="connectHeartRateMonitor()" class="bg-rose-100 text-rose-700 py-1 rounded-lg font-bold text-[10px] flex items-center justify-center gap-1 hover:bg-rose-200 transition-colors">
                                            <i data-lucide="bluetooth" size="12"></i> 藍牙連接心跳帶
                                        </button>
                                    </div>
                                    <i data-lucide="activity" class="absolute -right-2 -bottom-2 text-rose-200 w-16 h-16 z-0 opacity-40"></i>
                                </section>
                            </div>

                            <section class="relative bg-green-500 rounded-2xl p-4 text-white shadow-lg flex flex-col justify-between h-48 active:scale-95 transition-transform cursor-pointer border-b-4 border-green-700 overflow-hidden" onclick="openGoogleMapsNavigation()">
                                <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmZmZmYiIG9wYWNpdHk9IjAuMSIvPjwvc3ZnPg==')] opacity-50"></div>
                                <div class="relative z-10">
                                    <h2 class="text-2xl font-black mb-1 leading-tight">📍 帶我<br>回家</h2>
                                    <span class="text-[10px] bg-white/20 px-2 py-0.5 rounded-full backdrop-blur-sm mt-1 inline-block">Google Maps 導航</span>
                                </div>
                                <div class="relative z-10 self-end">
                                    <div class="bg-white/20 p-4 rounded-full backdrop-blur-sm shadow-inner animate-bounce mt-2">
                                        <i data-lucide="map-pinned" size="32" class="fill-white"></i>
                                    </div>
                                </div>
                            </section>
                        </div>

                        <!-- 緊急呼叫 (由長者觸發，傳給家人) -->
                        <button onclick="triggerSOS()" class="w-full bg-red-600 text-white rounded-3xl py-6 shadow-xl flex flex-row items-center justify-center gap-4 active:scale-95 transition-transform border-b-4 border-red-800 mb-4">
                            <div class="bg-white/20 p-3 rounded-full animate-pulse">
                                <i data-lucide="phone-call" size="32"></i>
                            </div>
                            <div class="text-left">
                                <span class="block text-2xl font-black tracking-wider drop-shadow-md">緊急呼叫</span>
                                <span class="block text-xs text-red-100 opacity-90 font-bold tracking-wide mt-1">通知家人 • 發送即時定位</span>
                            </div>
                        </button>

                        <div class="space-y-3">
                            <div class="bg-blue-50 p-4 rounded-2xl border border-blue-100 relative overflow-hidden">
                                <div class="absolute right-0 top-0 w-24 h-24 bg-blue-100 rounded-full blur-xl transform translate-x-1/2 -translate-y-1/2 opacity-60"></div>
                                <div class="flex items-center justify-between mb-2 relative z-10">
                                    <p class="text-sm font-bold text-gray-500 flex items-center gap-1"><i data-lucide="map-pin" size="14"></i> 目前位置：</p>
                                    <div class="flex gap-2">
                                        <button onclick="callGoogleMapGeminiFunction()" class="text-indigo-600 p-2 bg-white rounded-full shadow-sm hover:bg-indigo-100 transition-colors" title="Google Map x Gemini 智能路況分析"><i data-lucide="map" size="16"></i></button>
                                        <button onclick="readLocationReport()" class="text-blue-600 p-2 bg-white rounded-full shadow-sm hover:bg-blue-100 transition-colors" title="聆聽基本語音報告"><i data-lucide="volume-2" size="16"></i></button>
                                    </div>
                                </div>
                                <p class="text-lg font-black text-blue-700 leading-tight relative z-10" id="current-location-text">獲取真實地址中...</p>
                                <p id="report-env" class="text-xs text-slate-500 mt-2 italic font-medium border-t border-blue-100 pt-2 relative z-10">點擊上方 <i data-lucide="map" size="12" class="inline"></i> 圖示，讓 AI 分析周遭路況。</p>
                            </div>

                            <section class="bg-indigo-600 rounded-2xl p-4 text-white shadow-md">
                                <div class="flex items-center justify-between mb-3">
                                    <div class="flex items-center gap-2">
                                        <i data-lucide="sparkles" class="text-yellow-300" size="18"></i>
                                        <h3 class="text-sm font-bold tracking-wider">AI 智慧心情伴侶</h3>
                                    </div>
                                    <span class="text-[9px] bg-white/20 px-2 py-0.5 rounded-full">Gemini 支援</span>
                                </div>
                                <div id="ai-chat-box" class="bg-white/10 rounded-xl p-3 min-h-[50px] text-sm italic mb-3 border border-white/10 shadow-inner">
                                    「老友記，早晨！今日天氣唔錯，想去邊度行下呀？」
                                </div>
                                <div class="relative">
                                    <input type="text" id="ai-input" placeholder="問問 Gemini (例如：今日天氣點呀？)..." class="w-full bg-white/10 border border-white/20 rounded-xl pl-3 pr-12 py-2.5 text-sm text-white outline-none focus:bg-white/20 transition-colors focus:border-yellow-300/50">
                                    <button onclick="handleManualChat()" class="absolute right-2 top-1.5 p-1 text-yellow-400 hover:text-yellow-200 transition-colors rounded-full hover:bg-white/10"><i data-lucide="send" size="18"></i></button>
                                </div>
                            </section>
                        </div>
                        
                        <div class="mt-auto pt-4 border-t border-gray-100">
                            <button onclick="simulateLeaveSafeZone()" class="w-full bg-gray-50 text-gray-500 py-3 rounded-2xl text-xs font-bold border border-gray-200 hover:bg-gray-200 transition-colors shadow-sm flex items-center justify-center gap-2">
                                🧪 [演示] 模擬長者走出安全圍欄
                            </button>
                        </div>

                        <!-- ✨ 偏離路線警告 (長者專屬接收畫面) -->
                        <div id="wrong-way-overlay" class="hidden absolute inset-0 z-[5000] bg-orange-500 flex-col items-center justify-center text-white p-6 text-center transition-all duration-300 rounded-3xl">
                            <div class="absolute inset-0 bg-orange-600 animate-[pulse_2s_ease-in-out_infinite] opacity-60 rounded-3xl"></div>
                            <div class="relative z-10 flex flex-col items-center w-full max-w-sm">
                                <div class="bg-white p-6 rounded-full text-orange-500 mb-8 animate-bounce shadow-[0_0_40px_rgba(255,255,255,0.4)]">
                                    <i data-lucide="alert-triangle" size="64"></i>
                                </div>
                                <h1 class="text-4xl font-black mb-4 tracking-widest drop-shadow-md">注意安全</h1>
                                <p class="text-lg font-bold mb-8 opacity-95 leading-relaxed drop-shadow-sm">家人提醒您：<br>您似乎偏離了平時的路線，<br>請在原地等待聯絡，或開啟導航回家！</p>
                                <button onclick="closeWrongWayAlertLocal()" class="w-full bg-white text-orange-600 py-4 rounded-2xl font-black text-xl shadow-2xl active:scale-95 transition-transform hover:bg-gray-50 mb-4">我知道了</button>
                                <button onclick="openGoogleMapsNavigation()" class="w-full bg-green-500 text-white py-4 rounded-2xl font-black text-xl shadow-2xl active:scale-95 transition-transform hover:bg-green-600 flex justify-center items-center gap-2"><i data-lucide="map-pinned"></i> 立即帶我回家</button>
                            </div>
                        </div>

                    </div>
                </main>

                <!-- ================= 家人端介面 ================= -->
                <main id="page-family" class="hidden space-y-4 relative h-full">
                    <div class="bg-white p-4 rounded-3xl shadow-sm border-2 border-pink-100 relative h-full flex flex-col">
                        <h3 class="text-pink-600 font-black mb-4 text-center tracking-widest text-sm bg-pink-50 py-1 rounded-full w-1/2 mx-auto">❤️ 家人監護端</h3>
                        
                        <!-- SOS 通知彈窗 (家人專屬接收畫面) -->
                        <div id="sos-alert" class="hidden bg-red-50 border-2 border-red-500 p-4 rounded-2xl mb-4 shadow-lg animate-[pulse_1.5s_ease-in-out_infinite]">
                            <div class="flex items-center gap-3 text-red-700 mb-3">
                                <div class="bg-red-200 p-2 rounded-full shadow-inner"><i data-lucide="alert-triangle" size="28"></i></div>
                                <div>
                                    <span class="block font-black text-lg tracking-wider">緊急求助警報！</span>
                                    <span class="block text-sm font-bold text-red-600/80">長者已觸發 SOS 按鈕</span>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                <button onclick="openMap()" class="w-2/3 bg-red-600 text-white py-3.5 rounded-xl font-black text-sm flex items-center justify-center gap-2 shadow-[0_4px_14px_0_rgba(220,38,38,0.39)] hover:bg-red-700 active:scale-95 transition-all">
                                    <i data-lucide="map-pin"></i> 獲取真實定位
                                </button>
                                <button onclick="closeSOSAlertLocal()" class="w-1/3 bg-red-100 text-red-700 py-3.5 rounded-xl font-bold text-sm hover:bg-red-200 active:scale-95 transition-all">
                                    關閉
                                </button>
                            </div>
                        </div>

                        <!-- 4 項實時數據監控 -->
                        <div class="grid grid-cols-4 gap-2 mb-5 text-center divide-x divide-gray-200 bg-gray-50 p-3.5 rounded-2xl border border-gray-200 shadow-inner">
                            <div class="flex flex-col items-center justify-center">
                                <p class="text-[10px] text-gray-500 font-bold mb-1">心率</p>
                                <div class="flex items-baseline gap-0.5">
                                    <p id="family-heart-rate" class="text-xl font-black text-rose-600 leading-none step-update inline-block">--</p>
                                </div>
                            </div>
                            <div class="flex flex-col items-center justify-center">
                                <p class="text-[10px] text-gray-500 font-bold mb-1">步數</p>
                                <div class="flex items-baseline gap-0.5">
                                    <p id="family-step-count" class="text-xl font-black text-blue-600 step-update inline-block leading-none">0</p>
                                </div>
                            </div>
                            <div class="flex flex-col items-center justify-center">
                                <p class="text-[10px] text-gray-500 font-bold mb-1">電量</p>
                                <div class="flex items-baseline gap-0.5">
                                    <p id="family-battery-level" class="text-xl font-black text-green-600 leading-none">85%</p>
                                </div>
                            </div>
                            <div class="flex flex-col items-center justify-center">
                                <p class="text-[10px] text-gray-500 font-bold mb-1">GPS</p>
                                <div class="flex items-center gap-1 mt-1">
                                    <span id="family-gps-dot" class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span>
                                    <p id="family-gps-status" class="text-[10px] font-bold text-gray-500 leading-none tracking-wide">未同步</p>
                                </div>
                            </div>
                        </div>

                        <!-- 歷史軌跡簡介 -->
                        <section class="bg-amber-50 p-4 rounded-2xl border border-amber-200 mb-5 relative overflow-hidden">
                            <i data-lucide="history" class="absolute -right-4 -bottom-4 text-amber-100 w-24 h-24 z-0 opacity-60"></i>
                            <h3 class="font-bold text-amber-800 flex items-center gap-2 mb-2 text-sm relative z-10">
                                <i data-lucide="map-pin" size="16"></i> 實時同步街道位置：
                            </h3>
                            <p id="family-address-text" class="text-sm text-amber-900 font-black relative z-10">等待接收長者定位...</p>
                        </section>

                        <!-- 主要功能按鈕網格 -->
                        <div class="grid grid-cols-2 gap-3 mb-4">
                            <button onclick="openMap()" class="bg-blue-600 text-white p-4 rounded-2xl font-bold flex flex-col items-center justify-center gap-2 shadow-[0_4px_14px_0_rgba(37,99,235,0.39)] hover:bg-blue-700 active:scale-95 transition-all">
                                <i data-lucide="map-pin" size="24"></i> 實時定位
                            </button>
                            <button onclick="showHistory()" class="bg-amber-500 text-white p-4 rounded-2xl font-bold flex flex-col items-center justify-center gap-2 shadow-[0_4px_14px_0_rgba(245,158,11,0.39)] hover:bg-amber-600 active:scale-95 transition-all">
                                <i data-lucide="clock" size="24"></i> 24小時足跡
                            </button>
                        </div>
                        
                        <div class="space-y-3">
                            <button id="btn-safe-zone" onclick="openSafeZoneModal()" class="w-full bg-blue-50 text-blue-600 border border-blue-200 py-3.5 rounded-2xl font-bold text-sm hover:bg-blue-100 active:scale-95 transition-colors flex items-center justify-center gap-2">
                                <i data-lucide="shield-alert" size="18"></i> <span id="safe-zone-text">設定安全圍欄</span>
                            </button>
                            <!-- ✨ 傳送指令給長者按鈕 -->
                            <button onclick="sendWrongWayCommand()" class="w-full bg-orange-50 text-orange-600 border border-orange-200 py-3.5 rounded-2xl font-bold text-sm hover:bg-orange-100 active:scale-95 transition-colors flex items-center justify-center gap-2">
                                <i data-lucide="send" size="18"></i> 發送偏離路線警報給長者
                            </button>
                            <button id="btn-set-home" onclick="openSetHomeModal()" class="w-full bg-teal-50 text-teal-600 border border-teal-200 py-3.5 rounded-2xl font-bold text-sm hover:bg-teal-100 active:scale-95 transition-colors flex items-center justify-center gap-2">
                                <i data-lucide="home" size="18"></i> <span id="set-home-text">設定住家位置 (導航終點)</span>
                            </button>
                        </div>

                        <!-- 智慧簡報 -->
                        <section class="mt-auto pt-4">
                            <div class="bg-white p-4 rounded-2xl shadow-sm border border-indigo-100">
                                <div class="flex items-center gap-2 mb-3">
                                    <div class="bg-indigo-100 p-1.5 rounded-lg text-indigo-600"><i data-lucide="brain-circuit" size="16"></i></div>
                                    <h4 class="text-sm font-bold text-gray-800">Gemini 智慧簡報</h4>
                                </div>
                                <div id="family-ai-summary" class="text-xs text-gray-600 leading-relaxed italic bg-gray-50 p-3 rounded-xl border border-gray-100 min-h-[60px]">
                                    等待接收長者數據進行分析...
                                </div>
                            </div>
                        </section>
                    </div>
                </main>
                
            </div>
        </div>
    </div>

    <!-- ================= 模態框與全螢幕覆蓋層 ================= -->

    <div id="custom-alert-modal" class="hidden fixed inset-0 z-[7000] bg-black/70 flex items-center justify-center p-4 backdrop-blur-sm transition-opacity duration-300">
